{
  "expo": {
    "name": "Simple Call Blocker",
    "slug": "android-call-filter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_512.png",
    "scheme": "callfilter",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo_512.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#3949ab"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.cadence.callblocker"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "./plugins/withCallScreening.js",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "e8c89a9f-3635-44e9-9578-52a3e8ff0b01"
      }
    },
  }
}
